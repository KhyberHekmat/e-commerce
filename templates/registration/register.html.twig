{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
    <section class="container">
        <div class="row">
            <div class="col">
                <h1>Register</h1>
                    {{ form_errors(registrationForm) }}

                    {{ form_start(registrationForm) }}
                        <fieldset class="mb-3">
                            <legend>Personal information</legend>
                             {{ form_row(registrationForm.firstname) }}
                             {{ form_row(registrationForm.lastname) }}
                             {{ form_row(registrationForm.email) }}
                        </fieldset>
                       
                       <fieldset class="mb-3">
                            <legend>Contact details</legend>
                             {{ form_row(registrationForm.address) }}
                             {{ form_row(registrationForm.zipcode) }}
                             {{ form_row(registrationForm.city) }}
                       </fieldset>
                        {{ form_row(registrationForm.plainPassword, {
                            label: 'Password'
                        }) }}
                        {{ form_row(registrationForm.agreeTerms) }}
                            <div class="mt-3">
                                <button type="submit" class="btn btn-lg btn-primary my-3">Register</button>
                                <a href="{{ path('app_login') }}" class="btn btn-lg btn-secondary">Sign in</a>
                            </div>
                        {{ form_end(registrationForm) }}
            </div>
        </div>
    </section>
    
{% endblock %}
