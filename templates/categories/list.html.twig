{% extends 'base.html.twig' %}

{% block title %} Product list per category {{ category.name }} {% endblock %}

{% block body %}
    <main class="container">
        <section class="row">
            <div class="col-12">
                <h2>Product list per category {{ category.name }}</h2>
            </div>
            {% for product in products %}
                <div class="col-3 mb-3">
                    <article class="card h-100">
                        <div class="card-body">
                            <h3 class="card-title">{{ product.name }}</h3>
                            <p class="card-text">{{ product.description }} </p>
                            <a href="#" class="btn btn-primary">see the details</a>
                        </div>
                    </article>
                </div>
            {% endfor %}
        </section>
    </main>
{% endblock %}